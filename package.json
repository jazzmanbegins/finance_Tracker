{
  "name": "finance-tracker",
  "version": "1.0.0",
  "description": "Personal Finance Tracker",
  "author": "jazzmanbegins",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "electron:build": "electron-builder --win"
  },
  "dependencies": {
    "@seald-io/nedb": "^4.1.2",
    "express": "^4.19.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.financetracker.app",
    "productName": "Finance Tracker",
    "copyright": "© 2026 jazzmanbegins",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Finance Tracker"
    },
    "files": [
      "electron/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/mongodb-memory-server*/**/*",
      "!node_modules/parse-server*/**/*",
      "!node_modules/mongodb/**/*",
      "!.data/**/*",
      "!dist/**/*",
      "!cloud/**/*",
      "!mongodb-bin/**/*",
      "!server.js",
      "!start-finance.vbs",
      "!stop-finance.vbs"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      },
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "loading.html",
        "to": "loading.html"
      }
    ]
  }
}
